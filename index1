function buildOrderGrid(cat) {
  const grid = document.getElementById('orderGrid');
  grid.innerHTML = '';
  const filtered = cat === 'all' ? orderItems : orderItems.filter(i => i.cat === cat);
  document.getElementById('orderCountLabel').textContent = filtered.length + ' items';

  filtered.forEach(item => {
    const qty = cart[item.id] || 0;
    const row = document.createElement('div');
    row.className = 'order-item';
    row.id = 'orderRow_' + item.id;
    row.innerHTML = `
      <div class="order-item-emoji">${item.emoji}</div>
      <div class="order-item-info">
        <div class="order-item-name">${item.name}</div>
        <div class="order-item-desc">${item.desc}</div>
        <div class="order-item-price">${'₹ ' + item.price}</div>
      </div>
      <div class="qty-control">
        <button class="qty-btn" onclick="changeQty('${item.id}', 1)">+</button>
