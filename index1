════════════════════════════ */
function goTo(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  currentScreen = id;

  document.getElementById('appNav').style.display = 'flex';

  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  if (id === 'screen3D')    document.getElementById('navTab3D').classList.add('active');
  if (id === 'screenOrder') document.getElementById('navTabOrder').classList.add('active');
  if (id === 'screenMenu')  document.getElementById('navTabMenu').classList.add('active');

  window.scrollTo(0, 0);
}

/* ════════════════════════════
   BUILD 3D DISH CHIPS
════════════════════════════ */
function buildDishChips3D(cat) {
  const scroll = document.getElementById('dishScroll3D');
  scroll.innerHTML = '';
  const filtered = cat === 'all' ? dishes3D : dishes3D.filter(d => d.cat === cat);
  filtered.forEach((dish, i) => {
    const chip = document.createElement('div');
    chip.className = 'dish-chip3d' + (dish.id === currentDish3D.id ? ' active' : '');
    chip.innerHTML = `<div class="dish-chip3d-img">${dish.emoji}</div><div class="dish-chip3d-name">${dish.name.split(' ').slice(0,2).join(' ')}</div>`;
    chip.onclick = () => selectDish3D(dish, chip);
    scroll.appendChild(chip);
  });
}

function selectDish3D(dish, chipEl) {
  currentDish3D = dish;
  document.querySelectorAll('.dish-chip3d').forEach(c => c.classList.remove('active'));
  if (chipEl) chipEl.classList.add('active');

  document.getElementById('ddEmoji').textContent = dish.emoji;
  document.getElementById('ddName').textContent  = dish.name;
  document.getElementById('ddDesc').textContent  = dish.desc;
  document.getElementById('ddPrice').textContent = dish.price;

  const viewer = document.getElementById('dishViewer3D');
  const loader = document.getElementById('modelLoader3d');
  const noMod  = document.getElementById('noModel3d');
  const arBtn  = document.getElementById('arBtn3D');
  const hint   = document.getElementById('viewerHint');
  const dNote  = document.getElementById('dummyNote');

  if (dish.glb) {
    noMod.style.display = 'none';
    arBtn.style.display = 'flex';
    loader.style.display = 'flex';
    hint.textContent = 'Loading model…';
    dNote.style.display = 'none';
    viewer.setAttribute('src', dish.glb);
    viewer.setAttribute('ios-src', dish.usdz || '');
    viewer.addEventListener('load', () => {
      loader.style.display = 'none';
      hint.textContent = 'Drag to rotate · Pinch to zoom';
      if (dish.dummyNote) {
        dNote.textContent = dish.dummyNote;
        dNote.style.display = 'block';
      }
    }, { once: true });
    setTimeout(() => { loader.style.display = 'none'; }, 10000);
  } else {
    viewer.removeAttribute('src');
    arBtn.style.display = 'none';
    loader.style.display = 'none';
    noMod.style.display = 'block';
    dNote.style.display = 'none';
    hint.textContent = '';
  }
}

