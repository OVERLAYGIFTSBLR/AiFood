  buildOrderGrid(cat);
}

function changeQty(id, delta) {
  cart[id] = Math.max(0, (cart[id] || 0) + delta);
  if (cart[id] === 0) delete cart[id];
  const qtyEl = document.getElementById('qty_' + id);
  if (qtyEl) qtyEl.textContent = cart[id] || '—';
  updateCartBar();
}

function updateCartBar() {
  const bar = document.getElementById('cartBar');
  const count = Object.values(cart).reduce((a,b) => a+b, 0);
  const total = Object.entries(cart).reduce((sum, [id, qty]) => {
    const item = orderItems.find(i => i.id === id);
    return sum + (item ? item.price * qty : 0);
  }, 0);
  document.getElementById('cartCountBadge').textContent = count;
  document.getElementById('cartTotalBar').textContent = '₹ ' + total.toLocaleString('en-IN');
  bar.classList.toggle('visible', count > 0);
}

/* ════════════════════════════
   CART MODAL
════════════════════════════ */
function openCart() {
  const modal = document.getElementById('cartModal');
  const items = document.getElementById('cartItems');
  const total = document.getElementById('cartTotalModal');
  items.innerHTML = '';
  let sum = 0;
  Object.entries(cart).forEach(([id, qty]) => {
    const item = orderItems.find(i => i.id === id);
    if (!item) return;
    const sub = item.price * qty;
    sum += sub;
    items.innerHTML += `<div class="cart-row">
      <div class="cart-row-emoji">${item.emoji}</div>
      <div class="cart-row-name">${item.name}</div>
      <div class="cart-row-qty">× ${qty}</div>
      <div class="cart-row-price">₹ ${sub.toLocaleString('en-IN')}</div>
    </div>`;
  });
  total.textContent = '₹ ' + sum.toLocaleString('en-IN');
  modal.classList.add('open');
}

/* ════════════════════════════
   WHATSAPP KOT CONFIG
   ↓ Change these two numbers ↓
════════════════════════════ */
const KITCHEN_WHATSAPP   = '919XXXXXXXXX'; // Kitchen WhatsApp number (with country code, no +)
const BILLING_WHATSAPP   = '919XXXXXXXXX'; // Billing counter WhatsApp number

const TABLE_NUMBER = '07';
const TABLE_INFO   = 'Indoor · Window Seat';

function generateOrderId() {
  return '#ORD-' + Math.floor(1000 + Math.random() * 9000);
}

function buildKOTMessage(orderId, cartSnapshot, note, total) {
  const now = new Date();
  const time = now.toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit', hour12:true });
  const date = now.toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' });

  let lines = '';
  cartSnapshot.forEach(({ item, qty }) => {
    const sub = (item.price * qty).toLocaleString('en-IN');
    lines += `${item.emoji} ${item.name.padEnd(18)} x${qty}   ₹${sub}\n`;
  });

  const msg =
`🍽️ *NEW ORDER — KOT*
━━━━━━━━━━━━━━━━━━━━
*Table  :* ${TABLE_NUMBER}
*Seat   :* ${TABLE_INFO}
*Order  :* ${orderId}
*Time   :* ${time}, ${date}
━━━━━━━━━━━━━━━━━━━━
${lines}━━━━━━━━━━━━━━━━━━━━
*TOTAL  :* ₹${total.toLocaleString('en-IN')}
━━━━━━━━━━━━━━━━━━━━${note ? `\n📝 *Note:* ${note}` : ''}
_Sent via Sakura AR Menu_`;

  return msg;
}

function placeOrder() {
  // Snapshot cart before clearing
  const cartSnapshot = [];
  let total = 0;
  Object.entries(cart).forEach(([id, qty]) => {
    const item = orderItems.find(i => i.id === id);
    if (!item) return;
    cartSnapshot.push({ item, qty });
    total += item.price * qty;
  });

  if (cartSnapshot.length === 0) return;

  const orderId = generateOrderId();
  const note    = document.getElementById('specialNote').value.trim();
  const msg     = buildKOTMessage(orderId, cartSnapshot, note, total);

  // Close cart modal
  document.getElementById('cartModal').classList.remove('open');

  // Show success screen
  const successEl = document.getElementById('orderSuccess');
  successEl.style.display = 'flex';
  document.getElementById('successOrderId').textContent = orderId + ' · Table ' + TABLE_NUMBER;

  // KOT preview (formatted nicely for the success card)
  let previewLines = '';
  cartSnapshot.forEach(({ item, qty }) => {
    previewLines += `${item.emoji} ${item.name} × ${qty}   ₹${(item.price * qty).toLocaleString('en-IN')}\n`;
  });
  previewLines += `\nTotal: ₹${total.toLocaleString('en-IN')}`;
  if (note) previewLines += `\n📝 ${note}`;
  document.getElementById('kotPreview').textContent = previewLines;

  // Send to Kitchen WhatsApp
  const kitchenURL  = `https://wa.me/${KITCHEN_WHATSAPP}?text=${encodeURIComponent(msg)}`;
  const billingURL  = `https://wa.me/${BILLING_WHATSAPP}?text=${encodeURIComponent(msg)}`;

  // Open kitchen WhatsApp after short delay
  setTimeout(() => { window.open(kitchenURL, '_blank'); }, 600);

  // If billing is a different number, open after another delay
  if (BILLING_WHATSAPP !== KITCHEN_WHATSAPP) {
    setTimeout(() => { window.open(billingURL, '_blank'); }, 1800);
  }

  // Clear cart & reset
  Object.keys(cart).forEach(k => delete cart[k]);
  document.getElementById('specialNote').value = '';
  buildOrderGrid(currentCatOrder);
  updateCartBar();
}

function closeSuccess() {
  document.getElementById('orderSuccess').style.display = 'none';
}

document.getElementById('cartModal').addEventListener('click', function(e) {
  if (e.target === this) this.classList.remove('open');
});

