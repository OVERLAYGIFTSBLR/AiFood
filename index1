<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no"/>
  <title>AR Menu | Sakura Dining</title>
  <link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;500;600;700&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet"/>
  <script type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>
  <style>
    :root {
      --ink:      #0C0A08;
      --paper:    #F7F0E6;
      --red:      #C0392B;
      --red2:     #E8523F;
      --gold:     #B8943A;
      --gold2:    #D4AF60;
      --ash:      #2A2420;
      --mist:     rgba(247,240,230,0.5);
      --glass:    rgba(12,10,8,0.82);
      --glass2:   rgba(247,240,230,0.06);
      --ff-disp:  'Shippori Mincho', serif;
      --ff-body:  'DM Sans', sans-serif;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      width: 100vw; min-height: 100vh; overflow-x: hidden;
      font-family: var(--ff-body);
      background: var(--ink);
      color: var(--paper);
      -webkit-tap-highlight-color: transparent;
    }

    /* ── NOISE OVERLAY ── */
    body::before {
      content: ''; position: fixed; inset: 0; pointer-events: none; z-index: 9999;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.78' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.028'/%3E%3C/svg%3E");
      opacity: 0.5;
    }

    /* ══════════════════════════════
       SCREEN MANAGER
    ══════════════════════════════ */
    .screen { display: none; }
    .screen.active { display: block; }

    /* ══════════════════════════════
       LANDING SCREEN
    ══════════════════════════════ */
    #screenLanding {
      min-height: 100vh;
      background:
        radial-gradient(ellipse 80% 60% at 15% 10%, rgba(192,57,43,0.18) 0%, transparent 55%),
        radial-gradient(ellipse 60% 40% at 85% 90%, rgba(184,148,58,0.12) 0%, transparent 50%),
        #0C0A08;
      display: flex; flex-direction: column;
      align-items: center; justify-content: space-between;
      padding: 48px 24px 40px;
      position: relative; overflow: hidden;
    }
    /* Japanese pattern background */
    #screenLanding::after {
      content: ''; position: absolute; inset: 0; pointer-events: none; opacity: 0.04;
      background-image: repeating-linear-gradient(0deg, var(--paper) 0px, var(--paper) 1px, transparent 1px, transparent 40px),
                        repeating-linear-gradient(90deg, var(--paper) 0px, var(--paper) 1px, transparent 1px, transparent 40px);
    }
    .landing-top { text-align: center; position: relative; z-index: 2; }
    .brand-mon {
      width: 56px; height: 56px; border-radius: 50%;
      border: 1px solid rgba(192,57,43,0.4);
      display: flex; align-items: center; justify-content: center;
      font-size: 24px; margin: 0 auto 16px;
      background: rgba(192,57,43,0.08);
      position: relative;
    }
    .brand-mon::after {
      content: ''; position: absolute; inset: -5px; border-radius: 50%;
      border: 1px solid rgba(192,57,43,0.15);
    }
    .brand-en {
      font-family: var(--ff-disp); font-size: 40px; font-weight: 600;
      color: var(--paper); letter-spacing: 0.04em; line-height: 1;
    }
    .brand-jp {
      font-size: 10px; font-weight: 300; letter-spacing: 0.42em;
      color: rgba(192,57,43,0.7); margin-top: 6px; text-transform: uppercase;
    }

    /* Service cards */
    .service-cards { width: 100%; max-width: 380px; position: relative; z-index: 2; margin: 32px 0; }
    .service-card {
      background: var(--glass2); border: 1px solid rgba(247,240,230,0.08);
      border-radius: 16px; padding: 16px 18px; margin-bottom: 10px;
      display: flex; align-items: center; gap: 14px;
      backdrop-filter: blur(12px);
      cursor: pointer; transition: all 0.2s ease;
    }
    .service-card:hover, .service-card:active { border-color: rgba(192,57,43,0.35); background: rgba(192,57,43,0.06); transform: translateX(4px); }
    .svc-icon {
      width: 42px; height: 42px; border-radius: 12px; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center; font-size: 20px;
    }
    .svc-icon.red  { background: rgba(192,57,43,0.15); border: 1px solid rgba(192,57,43,0.2); }
    .svc-icon.gold { background: rgba(184,148,58,0.15); border: 1px solid rgba(184,148,58,0.2); }
    .svc-icon.ash  { background: rgba(247,240,230,0.06); border: 1px solid rgba(247,240,230,0.1); }
    .svc-label {
      font-family: var(--ff-disp); font-size: 15px; font-weight: 500; color: var(--paper);
      margin-bottom: 2px;
    }
    .svc-desc { font-size: 11px; font-weight: 300; color: rgba(247,240,230,0.4); line-height: 1.4; }
    .svc-arrow { margin-left: auto; font-size: 16px; color: rgba(247,240,230,0.2); flex-shrink: 0; }

    .landing-cta { width: 100%; max-width: 380px; position: relative; z-index: 2; }
    .cta-main {
      width: 100%; padding: 17px;
      background: var(--red); border: none; border-radius: 14px;
      font-family: var(--ff-body); font-size: 15px; font-weight: 500;
      color: #fff; letter-spacing: 0.05em; cursor: pointer;
      box-shadow: 0 8px 32px rgba(192,57,43,0.4);
      transition: transform 0.15s, box-shadow 0.15s;
    }
    .cta-main:active { transform: scale(0.97); box-shadow: 0 4px 16px rgba(192,57,43,0.3); }
    .cta-note { text-align: center; margin-top: 10px; font-size: 9.5px; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(247,240,230,0.18); }

    /* ══════════════════════════════
       NAV (shared across screens 2-4)
    ══════════════════════════════ */
    .app-nav {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 500;
      padding: 10px 6px calc(10px + env(safe-area-inset-bottom));
      background: linear-gradient(0deg, rgba(8,6,4,0.98) 0%, rgba(12,10,8,0.95) 100%);
      border-top: 1px solid rgba(247,240,230,0.07);
      backdrop-filter: blur(20px);
      display: flex; justify-content: space-around; align-items: center;
    }
    .nav-tab {
      flex: 1; display: flex; flex-direction: column; align-items: center;
      gap: 4px; padding: 8px 4px; border: none; background: none;
      cursor: pointer; transition: opacity 0.2s;
    }
    .nav-tab-icon { font-size: 20px; line-height: 1; }
    .nav-tab-label { font-size: 9px; font-weight: 400; letter-spacing: 0.1em; color: rgba(247,240,230,0.3); text-transform: uppercase; transition: color 0.2s; }
    .nav-tab.active .nav-tab-label { color: var(--red); }
    .nav-tab-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--red); opacity: 0; transition: opacity 0.2s; }
    .nav-tab.active .nav-tab-dot { opacity: 1; }

    /* ══════════════════════════════
       SCREEN: 3D DISH VIEWER
    ══════════════════════════════ */
    #screen3D {
      min-height: 100vh;
      background: radial-gradient(ellipse 100% 50% at 50% 0%, rgba(42,36,32,0.8) 0%, #0C0A08 60%);
    }
    .screen-header {
      padding: 52px 20px 16px;
      display: flex; align-items: flex-end; justify-content: space-between;
    }
    .screen-title { font-family: var(--ff-disp); font-size: 30px; font-weight: 600; color: var(--paper); line-height: 1.1; }
    .screen-sub { font-size: 11px; font-weight: 300; color: rgba(247,240,230,0.35); margin-top: 4px; letter-spacing: 0.1em; }
    .screen-badge {
      font-size: 9px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--red); background: rgba(192,57,43,0.12);
      border: 1px solid rgba(192,57,43,0.25); border-radius: 20px;
      padding: 5px 10px;
    }

    /* Category pills */
    .cat-strip {
      display: flex; gap: 8px; padding: 0 20px 16px;
      overflow-x: auto; scrollbar-width: none;
    }
    .cat-strip::-webkit-scrollbar { display: none; }
    .cat-pill {
      flex-shrink: 0; padding: 7px 16px;
      border-radius: 20px; border: 1px solid rgba(247,240,230,0.1);
      background: rgba(247,240,230,0.04);
      font-size: 11px; font-weight: 400; color: rgba(247,240,230,0.45);
      cursor: pointer; transition: all 0.18s; white-space: nowrap;
    }
    .cat-pill.active {
      background: var(--red); border-color: var(--red);
      color: #fff;
    }

    /* 3D Viewer area */
    .viewer-wrap {
      position: relative; height: 280px; margin: 0 20px;
      border-radius: 20px; overflow: hidden;
      background: linear-gradient(135deg, rgba(42,36,32,0.6), rgba(20,15,10,0.8));
      border: 1px solid rgba(247,240,230,0.07);
    }
    #dishViewer3D {
      width: 100%; height: 100%;
      --poster-color: transparent;
      background: transparent;
    }
    .viewer-overlay-tl {
      position: absolute; top: 12px; left: 14px; pointer-events: none;
      display: flex; align-items: center; gap: 6px;
    }
    .viewer-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--red); animation: blink 2s ease infinite; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
    .viewer-live { font-size: 9px; font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(247,240,230,0.5); }
    .viewer-hint {
      position: absolute; bottom: 14px; left: 50%; transform: translateX(-50%);
      font-size: 10px; font-weight: 300; letter-spacing: 0.18em; text-transform: uppercase;
      color: rgba(247,240,230,0.35); white-space: nowrap; pointer-events: none;
    }
    .ar-trigger {
      position: absolute; bottom: 14px; right: 14px;
      background: var(--red); border: none; border-radius: 50px;
      padding: 10px 16px; font-family: var(--ff-body); font-size: 11px; font-weight: 500;
      color: #fff; letter-spacing: 0.06em; cursor: pointer;
      display: flex; align-items: center; gap: 6px;
      box-shadow: 0 4px 20px rgba(192,57,43,0.45);
      animation: pulsered 2.5s ease infinite;
    }
    @keyframes pulsered {
      0%,100%{box-shadow:0 4px 20px rgba(192,57,43,0.4)} 50%{box-shadow:0 4px 36px rgba(192,57,43,0.7)}
    }

    /* Dish detail card */
    .dish-detail {
      margin: 14px 20px 0;
      background: var(--glass2); border: 1px solid rgba(247,240,230,0.07);
      border-radius: 18px; padding: 16px;
      backdrop-filter: blur(12px);
      display: flex; align-items: flex-start; gap: 14px;
    }
    .dish-detail-emoji { font-size: 38px; flex-shrink: 0; }
    .dish-detail-name { font-family: var(--ff-disp); font-size: 20px; font-weight: 500; color: var(--paper); }
    .dish-detail-desc { font-size: 11.5px; font-weight: 300; color: rgba(247,240,230,0.45); line-height: 1.6; margin: 4px 0 8px; }
    .dish-detail-row { display: flex; align-items: center; justify-content: space-between; }
    .dish-detail-price { font-family: var(--ff-disp); font-size: 20px; color: var(--gold2); }
    .dish-detail-tags { display: flex; gap: 6px; }
    .dish-tag {
      font-size: 9px; letter-spacing: 0.1em; padding: 3px 8px; border-radius: 10px;
      font-weight: 400; text-transform: uppercase;
    }
    .tag-veg { background: rgba(46,125,50,0.15); color: #81C784; border: 1px solid rgba(46,125,50,0.25); }
    .tag-spicy { background: rgba(192,57,43,0.12); color: #EF9A9A; border: 1px solid rgba(192,57,43,0.2); }
    .tag-popular { background: rgba(184,148,58,0.12); color: var(--gold2); border: 1px solid rgba(184,148,58,0.2); }

    /* Dish scroll grid */
    .dish-row-title {
      font-size: 10px; font-weight: 400; letter-spacing: 0.2em; text-transform: uppercase;
      color: rgba(247,240,230,0.25); padding: 18px 20px 10px;
    }
    .dish-chips-scroll {
      display: flex; gap: 10px; padding: 0 20px 100px;
      overflow-x: auto; scrollbar-width: none;
    }
    .dish-chips-scroll::-webkit-scrollbar { display: none; }
    .dish-chip3d {
      flex-shrink: 0; width: 80px; cursor: pointer; transition: transform 0.15s;
    }
    .dish-chip3d:active { transform: scale(0.92); }
    .dish-chip3d-img {
      width: 80px; height: 80px; border-radius: 16px;
      background: rgba(247,240,230,0.05); border: 1.5px solid rgba(247,240,230,0.08);
      display: flex; align-items: center; justify-content: center; font-size: 30px;
      margin-bottom: 6px; transition: all 0.2s;
    }
    .dish-chip3d.active .dish-chip3d-img { border-color: var(--red); background: rgba(192,57,43,0.1); }
    .dish-chip3d-name { font-size: 9.5px; font-weight: 300; color: rgba(247,240,230,0.4); text-align: center; line-height: 1.3; }
    .dish-chip3d.active .dish-chip3d-name { color: var(--paper); }

    /* No model note */
    .no-model-badge {
      position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
      font-size: 11px; font-weight: 300; letter-spacing: 0.14em; text-transform: uppercase;
      color: rgba(247,240,230,0.25); white-space: nowrap; pointer-events: none;
    }

    /* ══════════════════════════════
       SCREEN: AR TABLE ORDER
    ══════════════════════════════ */
    #screenOrder {
      min-height: 100vh;
      background: radial-gradient(ellipse 80% 40% at 80% 0%, rgba(184,148,58,0.08) 0%, transparent 55%), #0C0A08;
    }

    .table-id-bar {
      margin: 0 20px 16px;
      background: rgba(184,148,58,0.08); border: 1px solid rgba(184,148,58,0.18);
      border-radius: 12px; padding: 11px 16px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .table-id-left { display: flex; align-items: center; gap: 10px; }
    .table-num-badge {
      width: 36px; height: 36px; border-radius: 10px;
      background: rgba(184,148,58,0.15); border: 1px solid rgba(184,148,58,0.25);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--ff-disp); font-size: 17px; font-weight: 600; color: var(--gold2);
    }
    .table-id-info .t-label { font-size: 9px; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(247,240,230,0.3); }
    .table-id-info .t-val   { font-size: 13px; font-weight: 400; color: var(--paper); margin-top: 1px; }
    .table-scan-btn {
      font-size: 10px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--gold2); background: none; border: 1px solid rgba(184,148,58,0.25);
      border-radius: 8px; padding: 7px 12px; cursor: pointer;
    }

    /* Order menu categories */
    .order-section-title {
      font-family: var(--ff-disp); font-size: 18px; font-weight: 500;
      color: var(--paper); padding: 0 20px 12px; display: flex; align-items: center; justify-content: space-between;
    }
    .order-section-title span { font-family: var(--ff-body); font-size: 10px; font-weight: 300; color: rgba(247,240,230,0.3); }

    .order-grid { display: flex; flex-direction: column; gap: 10px; padding: 0 20px; }
    .order-item {
      background: var(--glass2); border: 1px solid rgba(247,240,230,0.07);
      border-radius: 16px; padding: 14px; display: flex; align-items: center; gap: 14px;
    }
    .order-item-emoji { font-size: 32px; flex-shrink: 0; }
    .order-item-info { flex: 1; min-width: 0; }
    .order-item-name { font-family: var(--ff-disp); font-size: 16px; font-weight: 500; color: var(--paper); }
    .order-item-desc { font-size: 10.5px; font-weight: 300; color: rgba(247,240,230,0.35); line-height: 1.4; margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .order-item-price { font-size: 14px; font-weight: 400; color: var(--gold2); font-family: var(--ff-disp); margin-top: 4px; }
    .qty-control { display: flex; flex-direction: column; align-items: center; gap: 6px; flex-shrink: 0; }
    .qty-btn {
      width: 30px; height: 30px; border-radius: 10px; border: 1px solid rgba(247,240,230,0.12);
      background: rgba(247,240,230,0.05); color: var(--paper);
      font-size: 18px; line-height: 1; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.15s;
    }
    .qty-btn:active { background: rgba(192,57,43,0.2); }
    .qty-num { font-size: 16px; font-weight: 500; color: var(--paper); min-width: 20px; text-align: center; }

    /* Cart summary bar */
    .cart-bar {
      position: fixed; bottom: 68px; left: 16px; right: 16px; z-index: 400;
      background: var(--red); border-radius: 16px; padding: 14px 18px;
      display: none; align-items: center; justify-content: space-between;
      box-shadow: 0 8px 32px rgba(192,57,43,0.5);
      cursor: pointer; transition: transform 0.15s;
    }
    .cart-bar:active { transform: scale(0.98); }
    .cart-bar.visible { display: flex; }
    .cart-bar-left { display: flex; align-items: center; gap: 10px; }
    .cart-count-badge {
      width: 28px; height: 28px; border-radius: 8px;
      background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center;
      font-size: 13px; font-weight: 600; color: #fff;
    }
    .cart-label { font-size: 14px; font-weight: 500; color: #fff; }
    .cart-total { font-family: var(--ff-disp); font-size: 18px; color: #fff; }

    /* ══════════════════════════════
       SCREEN: FULL DIGITAL MENU
    ══════════════════════════════ */
    #screenMenu {
      min-height: 100vh;
      background: #0C0A08;
      padding-bottom: 100px;
    }

    .menu-hero {
      position: relative; height: 180px; overflow: hidden;
      background: linear-gradient(135deg, rgba(42,20,10,1) 0%, rgba(12,10,8,1) 100%);
      display: flex; align-items: flex-end; padding: 20px;
    }
    .menu-hero-bg {
      position: absolute; inset: 0;
      background:
        radial-gradient(circle at 20% 50%, rgba(192,57,43,0.25) 0%, transparent 40%),
        radial-gradient(circle at 80% 30%, rgba(184,148,58,0.15) 0%, transparent 35%);
    }
    .menu-hero-pattern {
      position: absolute; right: 0; top: 0; bottom: 0; width: 200px; opacity: 0.06;
      background-image: repeating-linear-gradient(45deg, var(--paper) 0, var(--paper) 1px, transparent 0, transparent 50%);
      background-size: 14px 14px;
    }
    .menu-hero-content { position: relative; z-index: 2; }
    .menu-hero-tag { font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(192,57,43,0.8); margin-bottom: 6px; }
    .menu-hero-title { font-family: var(--ff-disp); font-size: 34px; font-weight: 600; color: var(--paper); line-height: 1.05; }
    .menu-hero-sub { font-size: 11px; font-weight: 300; color: rgba(247,240,230,0.4); margin-top: 6px; }

    /* Menu sections */
    .menu-section { padding: 24px 20px 0; }
    .menu-section-head {
      display: flex; align-items: center; gap: 12px; margin-bottom: 14px;
    }
    .section-line { flex: 1; height: 1px; background: rgba(247,240,230,0.07); }
    .section-name {
      font-family: var(--ff-disp); font-size: 13px; font-weight: 500; font-style: italic;
      color: var(--gold2); letter-spacing: 0.06em; white-space: nowrap;
    }
    .section-jp { font-size: 11px; color: rgba(247,240,230,0.2); margin-left: 6px; }

    /* Menu item cards */
    .menu-card {
      background: var(--glass2); border: 1px solid rgba(247,240,230,0.06);
      border-radius: 16px; padding: 14px; margin-bottom: 10px;
      display: flex; gap: 14px; position: relative; overflow: hidden;
    }
    .menu-card::before {
      content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
      background: transparent; transition: background 0.2s;
    }
    .menu-card.featured::before { background: var(--red); }
    .menu-card-emoji { font-size: 36px; flex-shrink: 0; }
    .menu-card-body { flex: 1; min-width: 0; }
    .menu-card-name { font-family: var(--ff-disp); font-size: 17px; font-weight: 500; color: var(--paper); }
    .menu-card-jp   { font-size: 10px; color: rgba(247,240,230,0.2); margin: 1px 0 5px; letter-spacing: 0.08em; }
    .menu-card-desc { font-size: 11px; font-weight: 300; color: rgba(247,240,230,0.4); line-height: 1.55; margin-bottom: 8px; }
    .menu-card-foot { display: flex; align-items: center; justify-content: space-between; }
    .menu-card-price { font-family: var(--ff-disp); font-size: 17px; color: var(--gold2); }
    .menu-card-pills { display: flex; gap: 5px; }
    .menu-pill {
      font-size: 8.5px; letter-spacing: 0.08em; text-transform: uppercase;
      padding: 3px 7px; border-radius: 8px; font-weight: 400;
    }
    .pill-veg   { background: rgba(46,125,50,0.12); color: #A5D6A7; border: 1px solid rgba(46,125,50,0.2); }
    .pill-hot   { background: rgba(192,57,43,0.1); color: #EF9A9A;  border: 1px solid rgba(192,57,43,0.18); }
    .pill-chef  { background: rgba(184,148,58,0.1); color: var(--gold2); border: 1px solid rgba(184,148,58,0.18); }
    .pill-new   { background: rgba(30,100,180,0.1); color: #90CAF9;  border: 1px solid rgba(30,100,180,0.18); }

    .menu-card-right { display: flex; flex-direction: column; align-items: flex-end; justify-content: space-between; flex-shrink: 0; }
    .add-circle {
      width: 34px; height: 34px; border-radius: 50%;
      background: var(--red); border: none; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
